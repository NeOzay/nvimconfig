{
	"languageserver": {
		"lua":{
				"command": "lua-language-server",
				"args": ["-E", "-e", "LANG=en", "--configpath=~/.sumneko.json"],
				"rootPatterns": [".git","main.lua","init.lua"],
				"filetypes": ["lua"]
			}
		//"emmy":{
		//	"command":"java",
		//	"args": ["-cp", "~/EmmyLua-LS-all.jar", "com.tang.vscode.MainKt"],
		//	"rootPatterns": [".git","main.lua","init.lua"],
		//	"filetypes": ["lua"]
		//}
	},
	"suggest.completionItemKindLabels": {
		"method": " юЮЫ ",
		"function": " юЮЫ ",
		"variable": "[юЬЦ]",
		"field": " юЬЦ ",
		"typeParameter": "<яЮГ>",
		"constant": " яЫ╝ ",
		"class": " янД ",
		"interface": " яиа",
		"struct": " яЖ│ ",
		"event": " яГз ",
		"operator": " яЪФ ",
		"module": " яЩи ",
		"property": " яВн ",
		"enum": " яйЧ",
		"reference": " яТБ ",
		"keyword": " яЭз ",
		"file": " яЕЫ ",
		"folder": " я▒о ",
		"color": " юИл ",
		"unit": " яем ",
		"snippet": " яЧП ",
		"text": " яФл ",
		"constructor": " юИП ",
		"value": " явЯ ",
		"enumMember": " яЕЭ "
	},
	"sumneko-lua.enableNvimLuaDev": true,
	"Lua.semantic.enable": true,
	"Lua.semantic.keyword": false,
	"Lua.semantic.variable": true,
	"Lua.diagnostics.disable": [
		"lowercase-global"
	],
	"Lua.telemetry.enable": true,
	"semanticTokens.filetypes": ["*"],

	"suggest.autoTrigger": "always",
	"coc.source.file.triggerCharacters": [
		"/",
		"\\"
	],
	"coc.source.neco.enable": true,
	"coc.preferences.jumpCommand": "tab drop",
	"suggest.defaultSortMethod": "none"
}
